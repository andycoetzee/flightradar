# =============================================================================
#  FlightRadar - files that should NOT be committed
#  Everything here is generated by the build and reproducible from the sources
#  (platformio.ini, idf_component.yml and the vendored lib/ folder).
# =============================================================================

# ---- PlatformIO build output ----
.pio/

# ---- Old Arduino IDE build cache ----
build/

# ---- ESP-IDF managed components (re-downloaded from idf_component.yml) ----
managed_components/
dependencies.lock

# ---- Generated sdkconfig (produced from custom_sdkconfig in platformio.ini) ----
sdkconfig
sdkconfig.*
sdkconfig.defaults

# ---- pioarduino hybrid-compile scaffolding (regenerated every build) ----
.dummy/

# ---- Build logs / scratch ----
build_log.txt
_gitstatus.txt
_commitmsg.txt
_empty_tmp/

# ---- Hybrid-compile backup the pioarduino build leaves behind ----
*.orig

# ---- VS Code machine-specific files (keep extensions.json) ----
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# ---- OS junk ----
Thumbs.db
.DS_Store
